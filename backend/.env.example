PROJECT_NAME=NSE Intelligence API
ENVIRONMENT=local
DEBUG=false
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/nse_intelligence
REDIS_URL=redis://redis:6379/0
RAW_DATA_DIR=/app/external_data
LOCAL_DATA_DIR=/app/data
ARTIFACT_DIR=/app/artifacts
BOOTSTRAP_DATABASE=false
AUTO_TRAIN_MODELS=true
MODEL_RETRAIN_HOURS=24
PREDICTION_HORIZON_DAYS=5
RISK_DRAWDOWN_THRESHOLD=-0.05
BUY_RETURN_THRESHOLD=2.5
HOLD_RETURN_THRESHOLD=0.75
BUY_RISK_THRESHOLD=4.5
HOLD_RISK_THRESHOLD=6.5
RATE_LIMIT_PER_MINUTE=120
